\f0\fs24 \cf0 import os\
import torch\
import gc\
\
# 1. THE CLEANSER: Run this first to ensure the GPU is actually empty\
def clear_gpu():\
    torch.cuda.empty_cache()\
    gc.collect()\
    # Force single GPU and memory management\
    os.environ["CUDA_VISIBLE_DEVICES"] = "0"\
    os.environ["PYTORCH_CUDA_ALLOC_CONF"] = "expandable_segments:True"\
\
clear_gpu()\
\
from unsloth import FastLanguageModel, get_chat_template\
from trl import SFTTrainer\
from transformers import TrainingArguments\
from datasets import load_dataset\
\
# --- 1. CONFIGURATION ---\
model_name = "unsloth/Qwen2.5-0.5B-Instruct-bnb-4bit"\
max_seq_length = 2048 \
output_directory = "/kaggle/working/medical_qwen_model"\
\
if not os.path.exists(output_directory):\
    os.makedirs(output_directory)\
\
# --- 2. LOAD MODEL & LORA ---\
# Note: Unsloth handles the quantization loading internally to save VRAM\
model, tokenizer = FastLanguageModel.from_pretrained(\
    model_name = model_name,\
    max_seq_length = max_seq_length,\
    dtype = None, \
    load_in_4bit = True,\
)\
\
model = FastLanguageModel.get_peft_model(\
    model,\
    r = 16, \
    target_modules = ["q_proj", "k_proj", "v_proj", "o_proj",\
                      "gate_proj", "up_proj", "down_proj",],\
    lora_alpha = 16,\
    lora_dropout = 0, \
    bias = "none",    \
    use_gradient_checkpointing = "unsloth", \
    random_state = 3407,\
)\
\
# --- 3. DATASET PREP ---\
dataset = load_dataset("json", data_files="/kaggle/working/medical_finetune.jsonl", split="train")\
\
tokenizer = get_chat_template(\
    tokenizer,\
    chat_template = "qwen-2.5",\
    mapping = \{"role" : "role", "content" : "content", "user" : "user", "assistant" : "assistant"\},\
)\
\
def formatting_prompts_func(examples):\
    convos = examples["messages"]\
    texts = [tokenizer.apply_chat_template(convo, tokenize = False, add_generation_prompt = False) for convo in convos]\
    return \{ "text" : texts, \}\
\
print("Formatting dataset...")\
dataset = dataset.map(formatting_prompts_func, batched = True)\
\
# --- 4. ULTIMATE STABLE TRAINER ---\
trainer = SFTTrainer(\
    model = model,\
    tokenizer = tokenizer,\
    train_dataset = dataset,\
    dataset_text_field = "text",\
    max_seq_length = max_seq_length,\
    dataset_num_proc = 2,\
    packing = True, \
    args = TrainingArguments(\
        per_device_train_batch_size = 1,  # Keep this at 1 for T4 stability\
        gradient_accumulation_steps = 16, # Total batch size = 16\
        warmup_steps = 5,\
        max_steps = 1000, \
        learning_rate = 2e-4,\
        fp16 = not torch.cuda.is_bf16_supported(),\
        bf16 = torch.cuda.is_bf16_supported(),\
        logging_steps = 1,\
        optim = "adamw_8bit",\
        weight_decay = 0.01,\
        lr_scheduler_type = "linear",\
        seed = 3407,\
        output_dir = "outputs",\
        report_to = "none",\
    ),\
)\
\
# --- 5. RUN & SAVE ---\
print("\uc0\u55356 \u57283  Starting Training...")\
trainer_stats = trainer.train()\
\
print(f"\uc0\u55357 \u56510  Saving merged 16-bit model to \{output_directory\}...")\
model.save_pretrained_merged(output_directory, tokenizer, save_method = "merged_16bit")\
print("\uc0\u10024  Complete!")}