from datasets import load_dataset\
\
# 1. Load the dataset from Hugging Face\
print("Loading dataset...")\
dataset = load_dataset("OpenMed/Medical-Reasoning-SFT-Baichuan-M3-235B", split="train")\
\
def transform_row(row):\
    """\
    Strips reasoning_content and formats specifically for Qwen Instruct.\
    """\
    new_messages = []\
    for msg in row['messages']:\
        # Extract only the main answer/content\
        new_messages.append(\{\
            "role": msg['role'],\
            "content": msg['content']\
        \})\
    return \{"messages": new_messages\}\
\
# 2. Apply transformation and save to JSONL\
output_path = "/kaggle/working/medical_finetune.jsonl"\
print(f"Transforming and saving to \{output_path\}...")\
\
with open(output_path, "w", encoding="utf-8") as f:\
    for row in dataset:\
        formatted_row = transform_row(row)\
        f.write(json.dumps(formatted_row, ensure_ascii=False) + "\\n")\
\
print("Done! Dataset is ready for Qwen fine-tuning.")}